# Rinox Sentinel - Environment Variables

# Discord Bot Token (REQUIRED)
DISCORD_TOKEN=your_discord_bot_token_here

# Database
# Railway auto-injects DATABASE_URL when PostgreSQL plugin is added
DATABASE_URL=postgresql://user:pass@host:5432/rinox

# Cache (Redis) - Optional, falls back gracefully if unavailable
# Add Redis plugin on Railway and it will inject REDIS_URL
REDIS_URL=redis://localhost:6379/0

# Security
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# VirusTotal (Optional - for file scanning)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing (Optional - for URL scanning)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_api_key_here

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here

# Features
ENABLE_STREAMING=true
ENABLE_VISION=true
ENABLE_OCR=true
MAX_CACHE_SIZE=10000
